{
  "name": "vue3-colorful",
  "version": "0.1.0",
  "type": "module",
  "sideEffects": ["*.css"],
  "files": [
    "dist"
  ],
  "keywords": [
    "vue",
    "color-picker",
    "vue-colorful"
  ],
  "license": "MIT",
  "main": "./dist/vue3-colorful.umd.cjs",
  "module": "./dist/vue3-colorful.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue3-colorful.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/vue3-colorful.umd.cjs"
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:edonfy/vue3-colorful.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "peerDependencies": {
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "@edonfy/eslint-config": "^0.0.5",
    "@types/node": "^20.11.30",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitejs/plugin-vue-jsx": "^3.1.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.1",
    "typescript": "^5.2.2",
    "unocss": "^0.58.6",
    "vite": "^5.2.0",
    "vitest": "^4.1.0",
    "vue": "^3.4.21",
    "vue-tsc": "^2.0.6"
  }
}
